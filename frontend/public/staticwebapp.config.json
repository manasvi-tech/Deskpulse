{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "*.js",
      "*.css",
      "*.svg",
      "*.ico",
      "*.png",
      "*.json",
      "*.woff",
      "*.woff2"
    ]
  },
  "mimeTypes": {
    ".js": "application/javascript",
    ".mjs": "application/javascript",
    ".css": "text/css",
    ".html": "text/html",
    ".json": "application/json",
    ".svg": "image/svg+xml"
  }
}
