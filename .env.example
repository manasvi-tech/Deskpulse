# =============================================================================
# DeskPulse — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values as needed.
# For local Docker development, docker-compose.yml already pre-configures these.
# Never commit a .env file with real credentials.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Full connection string used by the backend pg Pool
DATABASE_URL=

# Individual DB components (used if not using DATABASE_URL)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
# HTTP port the Express server listens onP/
PORT=3001

# Node environment: development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# WebSocket
# -----------------------------------------------------------------------------
# WebSocket server port (usually same as PORT, upgrade on same server)
WS_PORT=3001

# -----------------------------------------------------------------------------
# Frontend (Vite build-time env vars — must be prefixed VITE_)
# -----------------------------------------------------------------------------
# Backend API base URL (used by frontend to make REST calls)
VITE_API_URL=http://localhost:3001

# WebSocket URL (used by frontend to connect)
VITE_WS_URL=ws://localhost:3001

# -----------------------------------------------------------------------------
# Simulator
# -----------------------------------------------------------------------------
# Default simulation speed multiplier: 1 | 5 | 10
SIMULATOR_DEFAULT_SPEED=1

# Interval in ms between simulated events at 1x speed
SIMULATOR_INTERVAL_MS=2000

AUTO_START_SIMULATOR=false
SIMULATOR_AUTO_RESUME_DELAY=30000

# -----------------------------------------------------------------------------
# Anomaly Detection
# -----------------------------------------------------------------------------
# How often the anomaly detector runs (milliseconds)
ANOMALY_DETECTOR_INTERVAL_MS=30000

# -----------------------------------------------------------------------------
# Materialized View Refresh
# -----------------------------------------------------------------------------
# How often gym_hourly_stats is refreshed (milliseconds) — 15 minutes
MV_REFRESH_INTERVAL_MS=900000

# -----------------------------------------------------------------------------
# Authentication & Sessions
# -----------------------------------------------------------------------------
# Enable demo mode (pre-fills login with demo credentials)
DEMO_MODE=true

# Secret used to sign session cookies — change in production
SESSION_SECRET=

# Secret used to sign JWT access tokens — change in production
JWT_SECRET=

# JWT expiry duration (e.g. 3d, 8h, 1h)
JWT_EXPIRY=3d

# -----------------------------------------------------------------------------
# Frontend (Vite build-time env vars — must be prefixed VITE_)
# -----------------------------------------------------------------------------
# Show demo login credentials on the login page
VITE_DEMO_MODE=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Pino log level: trace | debug | info | warn | error | fatal
# Use warn in production (Azure App Insights) to reduce noise
LOG_LEVEL=
